# docline environment template — committed to source control.
# Copy this file to .env.local (gitignored) and populate values.
#
#   cp .env.example .env.local
#
# Loader pattern (PowerShell):
#   Get-Content .env.local | ForEach-Object {
#     if ($_ -match '^\s*([A-Z_][A-Z0-9_]*)\s*=\s*(.+?)\s*$') {
#       Set-Item -Path "env:$($matches[1])" -Value $matches[2]
#     }
#   }

# -----------------------------------------------------------------------------
# Mistral OCR — required for --pdf-engine mistral_ocr
# Two access paths supported (Foundry preferred when both are set):
#
# Option A: Microsoft Foundry MaaS (preferred)
#   Get from: Azure portal > your Foundry resource > Models + Endpoints
# -----------------------------------------------------------------------------
AZURE_AI_FOUNDRY_ENDPOINT=https://your-resource.services.ai.azure.com/providers/mistral/azure/ocr
AZURE_AI_FOUNDRY_KEY=your-foundry-api-key-here

# Option B: Direct Mistral API (fallback when Foundry vars are not set)
#   Get from: https://console.mistral.ai/api-keys
# MISTRAL_API_KEY=your-mistral-api-key-here

# Optional model override (default: mistral-document-ai-2505)
# Other choices: mistral-ocr-2503 (March 2025 release)
# MISTRAL_OCR_MODEL=mistral-document-ai-2505
