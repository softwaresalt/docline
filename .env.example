# docline environment template — committed to source control.
# Copy this file to .env.local (gitignored) and populate values.
#
#   cp .env.example .env.local
#
# Loader pattern (PowerShell):
#   Get-Content .env.local | ForEach-Object {
#     if ($_ -match '^\s*([A-Z_][A-Z0-9_]*)\s*=\s*(.+?)\s*$') {
#       Set-Item -Path "env:$($matches[1])" -Value $matches[2]
#     }
#   }

# -----------------------------------------------------------------------------
# Azure Document Intelligence — required for --pdf-engine azure_di
# Get from: az cognitiveservices account show / keys list
#           (resource kind: FormRecognizer or AIServices)
# -----------------------------------------------------------------------------
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-64-character-hex-key-here

# Optional model override (default: prebuilt-layout)
# AZURE_DOCUMENT_INTELLIGENCE_MODEL_ID=prebuilt-layout
